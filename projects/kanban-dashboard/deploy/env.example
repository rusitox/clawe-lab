# /etc/openclaw-kanban.env  (also linked to /home/ubuntu/openclaw-kanban-v2/.env)
#
# Production environment for the docker-compose stack.
# After editing:  sudo chmod 0600 /etc/openclaw-kanban.env
#                 cd /home/ubuntu/openclaw-kanban-v2 && docker compose --env-file .env up -d

APP_ENV=production
APP_VERSION=2.0.0

# --- Image tag (set by deploy workflow; latest works for manual deploys) ---
APP_IMAGE=ghcr.io/rusitox/openclaw-kanban-v2:latest

# --- Host port (loopback bind for nginx to proxy to). Pick a unique port
#     when multiple apps share the VPS. Container itself stays on 8787.
HOST_PORT=8787

# --- Database ---
# Compose computes DATABASE_URL from these three; the app uses host=db (compose network).
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=CHANGE_ME_TO_A_RANDOM_24_CHAR_HEX_STRING
POSTGRES_DB=openclaw_kanban

# --- Sessions ---
# `openssl rand -hex 32` — rotate only during a planned downtime window.
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
SESSION_COOKIE_NAME=kanban_session
SESSION_MAX_AGE_SECONDS=2592000

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI MUST match OAUTH_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
OAUTH_REDIRECT_URI=https://kanban.example.com/auth/google/callback

# Optional allow-lists (CSV). Empty = open sign-up.
ALLOWED_EMAILS=
ALLOWED_DOMAINS=clawe.app

# --- Attachments ---
# Inside the container; the docker volume `attachments` is mounted here.
ATTACHMENTS_DIR=/app/var/attachments
ATTACHMENTS_MAX_BYTES=10485760

# --- Polling ---
POLL_INTERVAL_MS=8000

# --- Test bypass — MUST be false in production ---
TEST_AUTH_BYPASS=false

# --- Legacy v1 surface (Phase 6 soft cut) ---
# Set to the same token the old `python3 server.py` was using.
# Leave empty to disable /api/{tasks,activity,teams} entirely (returns 503).
LEGACY_KANBAN_TOKEN=
